	$(MAKE) $(MAKESILENT) -f CMakeFiles/tsundoku_lib.dir/build.make CMakeFiles/tsundoku_lib.dir/src/vulkan/vertex_buffer.cpp.s
.PHONY : src/vulkan/vertex_buffer.cpp.s

